<script>
  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var t = document.querySelector(this.getAttribute('href'));
      if (t) {
        e.preventDefault();
        t.scrollIntoView({ behavior: 'smooth', block: 'start' });
        var nc = document.getElementById('lbmNav2');
        if (nc && nc.classList.contains('show')) nc.classList.remove('show');
      }
    });
  });

  // FAQ accordion
  function toggleFAQ(btn) {
    var answer = btn.nextElementSibling;
    var isOpen = answer.classList.contains('open');
    // Close all
    document.querySelectorAll('.lbm-faq-a').forEach(function(a) { a.classList.remove('open'); });
    document.querySelectorAll('.lbm-faq-q').forEach(function(b) { b.classList.remove('open'); });
    // Open clicked (if wasn't open)
    if (!isOpen) {
      answer.classList.add('open');
      btn.classList.add('open');
    }
  }

  // Highlight active strip link on scroll
  var sections = document.querySelectorAll('.lbm-service-section');
  var stripLinks = document.querySelectorAll('.lbm-strip-link');
  window.addEventListener('scroll', function() {
    var scrollY = window.pageYOffset + 160;
    sections.forEach(function(sec) {
      if (scrollY >= sec.offsetTop && scrollY < sec.offsetTop + sec.offsetHeight) {
        stripLinks.forEach(function(l) { l.classList.remove('active'); });
        var active = document.querySelector('.lbm-strip-link[href="#' + sec.id + '"]');
        if (active) active.classList.add('active');
      }
    });
  });
</script>


