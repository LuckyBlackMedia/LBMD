  <!-- Form handler -->
  <script>
    (function() {
      var form    = document.getElementById('lbmContactForm');
      var btn     = document.getElementById('lbmSubmitBtn');
      var success = document.getElementById('lbmFormSuccess');
      var error   = document.getElementById('lbmFormError');

      if (!form) return;

      form.addEventListener('submit', function(e) {
        e.preventDefault();

        // Basic validation
        var name    = form.querySelector('#lbm-name').value.trim();
        var email   = form.querySelector('#lbm-email').value.trim();
        var service = form.querySelector('#lbm-service').value;
        var message = form.querySelector('#lbm-message').value.trim();

        if (!name || !email || !service || !message) {
          error.textContent = 'Please fill in all required fields.';
          error.style.display = 'block';
          success.style.display = 'none';
          return;
        }

        btn.textContent = 'Sending…';
        btn.disabled = true;
        success.style.display = 'none';
        error.style.display = 'none';

        var data = new FormData(form);

        // Google Apps Script requires no-cors mode for cross-origin POST.
        // We can't read the response body, so we assume success on completion.
        fetch(form.action, {
          method: 'POST',
          mode: 'no-cors',
          body: new URLSearchParams(data)
        })
        .then(function() {
          // Request completed — show success
          success.style.display = 'block';
          form.reset();
          btn.textContent = 'Message Sent ✓';
        })
        .catch(function(err) {
          error.textContent = 'Something went wrong. Please try again or email us directly.';
          error.style.display = 'block';
          btn.textContent = 'Send Inquiry';
          btn.disabled = false;
        });
      });
    })();
  </script>


